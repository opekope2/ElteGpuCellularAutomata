{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "CL_HPP_ENABLE_EXCEPTIONS",
                "CL_HPP_MINIMUM_OPENCL_VERSION=120",
                "CL_HPP_TARGET_OPENCL_VERSION=300"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "linux-gcc-x64",
            "compilerArgs": [
                "-std=c++20 -lOpenCL -lGL -lglfw -lEGL"
            ]
        }
    ],
    "version": 4
}